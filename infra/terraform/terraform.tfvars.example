# =============================================================================
# 开发环境变量值
# 复制此文件为 terraform.tfvars 并填入实际值
# =============================================================================

# 基础配置
project_name = "foodmoment"
environment  = "dev"
location     = "eastasia"  # 香港区域，国内访问延迟较低

# 数据库配置
db_admin_username = "fmadmin"
db_admin_password = "YourSecurePassword123!"  # 请更改为强密码（至少 12 字符）

# JWT 配置
jwt_secret_key = "your-super-secret-jwt-key-at-least-32-characters-long"

# AI 服务 - Anthropic (via Agent Maestro ngrok)
# 留空则 AI 识别返回 mock 数据
anthropic_base_url  = ""  # 例如: https://your-ngrok-domain.ngrok-free.dev/api/anthropic
anthropic_proxy_key = ""  # Agent Maestro proxy key

# CORS 配置
cors_allowed_origins = [
  "http://localhost:3000",
  "http://localhost:8080",
  "https://*.foodmoment.app"
]

# 额外标签
extra_tags = {
  Team    = "FoodMoment"
  Purpose = "Development"
}
